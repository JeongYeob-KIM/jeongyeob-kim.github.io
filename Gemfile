source "https://rubygems.org"

# GitHub Pages 환경과 호환되는 플러그인들을 자동으로 관리합니다.
# 이 한 줄이 있으면 jekyll-sitemap, jekyll-seo-tag 등을 별도로 적지 않아도 됩니다.
gem "github-pages", group: :jekyll_plugins

# 만약 로컬 환경에서 gem을 따로 설치해야 한다면 아래에 추가하세요.
# 단, GitHub Pages 빌드에서 에러를 일으키는 kramdown-math-katex, duktape는 제거하거나 주석 처리해야 합니다.
